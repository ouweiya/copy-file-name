{
  "name": "copy-file-name",
  "displayName": "Copy file name",
  "description": "Quickly copy file names",
  "version": "1.1.0",
  "publisher": "ouweiya",
  "repository": {
    "type": "git",
    "url": "https://github.com/ouweiya/copy-file-name.git"
  },
  "engines": {
    "vscode": "^1.41.0"
  },
  "keywords": [
    "sidebar",
    "copy-filename",
    "clipboard",
    "file",
    "folder"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:extension.copyFileName"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.copyFileName",
        "title": "复制文件名"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.copyFileName"
        }
      ],
      "editor/title/context": [
        {
          "command": "extension.copyFileName"
        }
      ]
    }
  },
  "scripts": {
    "up": "vsce publish"
  },
  "devDependencies": {
    "@types/glob": "^7.1.1",
    "@types/mocha": "^5.2.7",
    "@types/node": "^12.11.7",
    "@types/vscode": "^1.41.0",
    "eslint": "^6.6.0",
    "glob": "^7.1.5",
    "mocha": "^6.2.2",
    "typescript": "^3.6.4",
    "vscode-test": "^1.2.2"
  },
  "dependencies": {
    "clipboardy": "^2.1.0",
    "hoek": "^6.1.3"
  }
}
